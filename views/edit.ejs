<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Post</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen bg-black text-white">

    <!-- Header -->
    <div class="flex justify-between items-center px-16 py-6 bg-zinc-950 border-b border-zinc-800">
        <h1 class="text-2xl font-bold tracking-wide">
            <span class="text-purple-500">Task</span>Board
        </h1>

        <a href="/profile"
           class="px-5 py-2 bg-gradient-to-r from-purple-600 to-indigo-600 rounded-lg shadow-lg hover:scale-105 transition">
            Back
        </a>
    </div>

    <!-- Main Content -->
    <div class="max-w-2xl mx-auto px-16 py-16">

        <!-- Heading -->
        <div class="mb-2">
            <h2 class="text-4xl font-bold">
                Edit Your Task
            </h2>

            <p class="text-zinc-400 mt-4 text-lg">
                Make changes and keep moving forward.
            </p>
        </div>

        <!-- Edit Card -->
        <div class="bg-zinc-900 border border-zinc-700 rounded-2xl p-3 shadow-2xl max-w-xl">

            <form action="/edit/<%= post._id %>" method="post" class="space-y-6">

                <textarea 
                    name="content"
                    class="w-full p-2 rounded-xl bg-zinc-800 border border-zinc-700 focus:border-purple-500 focus:ring-2 focus:ring-purple-500 outline-none resize-none"
                    rows="4"
                    required><%= post.content %></textarea>

                <button 
                    class="w-full py-3 bg-gradient-to-r from-purple-500 to-orange-500 rounded-xl font-semibold shadow-lg hover:scale-105 transition duration-300">
                    Update Task
                </button>

            </form>

        </div>

    </div>

</body>
</html>