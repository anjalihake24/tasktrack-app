<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen bg-black text-white">

    <!-- Header -->
    <div class="flex justify-between items-center px-12 py-6 bg-zinc-950 border-b border-zinc-800">
        <h1 class="text-2xl font-bold tracking-wide">
            <span class="text-purple-500">Task</span>Board
        </h1>

        <a href="/logout"
            class="px-5 py-2 bg-gradient-to-r from-pink-600 to-red-500 rounded-lg shadow-lg hover:scale-105 transition">
            Logout
        </a>
    </div>

    <div class="max-w-4xl py-3 px-8 py-12">

        <!-- Welcome Section -->
        <div class="mb-4">
            <h2 class="text-4xl font-bold">
                Welcome back,
                <span class="bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
                    <%= user.name %>
                </span>
            </h2>
            <p class="text-zinc-400 mt-2 text-lg">
                Start building momentum today.
            </p>
        </div>

        <!-- Create Post Section -->
        <div class="bg-zinc-900 border border-zinc-700 rounded-2xl p-3 shadow-2xl">

            <form action="/post" method="post" class="space-y-6">

                <textarea name="content" placeholder="Write something powerful..."
                    class="w-full p-4 rounded-xl bg-zinc-800 border border-zinc-700 focus:border-purple-500 focus:ring-2 focus:ring-purple-500 outline-none transition resize-none text-white"
                    rows="4" required></textarea>

                <button
                    class="px-6 py-3 bg-gradient-to-r from-purple-600 to-indigo-600 rounded-xl font-semibold shadow-lg hover:shadow-purple-800/50 hover:scale-105 transition duration-300">
                    Create Post
                </button>

            </form>
        </div>

        <!-- Posts -->
        <div class="mt-8 space-y-4">

            <% [...user.posts].reverse().forEach(function(post){ %>

                <div
                    class="bg-zinc-900 border border-zinc-700 rounded-2xl p-2 shadow-xl hover:-translate-y-1 hover:shadow-purple-900/30 transition duration-300">

                    <div class="flex justify-between items-center mb-2">
                        <span class="text-purple-400 font-medium">
                            @<%= user.username %>
                        </span>


                    </div>

                    <p class="text-zinc-200 text-lg leading-relaxed">
                        <%= post.content %>
                    </p>

                    <div class="flex gap-8 mt-6 text-sm font-medium">

                        <a href="/like/<%= post._id %>">
                            <%= post.isCompleted ? "👍Done" : "⏳Pending" %>
                        </a>

                        <a href="/edit/<%= post._id %>" class="hover:text-blue-400 transition">
                            ✏ Edit
                        </a>

                    </div>

                </div>

                <% }) %>

        </div>

    </div>

</body>

</html>